{
  "name": "chronox",
  "packageManager": "bun@1.2.18",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "turbo run dev --filter=@chronox/web",
    "build:web": "turbo run build --filter=@chronox/web",
    "dev:tools": "turbo run dev --filter=@chronox/tools",
    "preview:web": "turbo run preview --filter=@chronox/web",
    "deploy:web": "turbo run deploy --filter=@chronox/web",
    "build:tools": "turbo run build --filter=@chronox/tools",
    "start:tools": "turbo run start --filter=@chronox/tools",
    "lint:web": "biome lint apps/web/src --max-diagnostics=1000",
    "lint:web:fix": "biome lint apps/web/src --write --unsafe --max-diagnostics=1000",
    "format:web": "biome format apps/web/src/services/renderer --write --max-diagnostics=1000",
    "test": "bun test",
    "generate:fonts": "npx tsx apps/web/scripts/generate-font-sprites.ts"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "better-auth": "^1.4.15",
    "next": "^16.1.3"
  },
  "devDependencies": {
    "turbo": "^2.8.20",
    "typescript": "5.8.3"
  },
  "resolutions": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide"
  ]
}
